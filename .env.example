# PostgreSQL connection string
DATABASE_URL="postgresql://portfolio:portfolio@localhost:5432/portfolio?schema=public"

# Admin credentials (server-side only)
ADMIN_USERNAME="your_username"
ADMIN_PASSWORD="your_secure_password"

# Session encryption secret — must be at least 32 characters
SESSION_SECRET="replace_with_a_long_random_secret_at_least_32_chars"
